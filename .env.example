# ──────────────────────────────────────────
# PasteHub Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# JWT Secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# PostgreSQL connection
DATABASE_URL=postgresql://pastehub:pastehub@localhost:5432/pastehub

# Postgres credentials (used by Docker Compose)
POSTGRES_USER=pastehub
POSTGRES_PASSWORD=pastehub
POSTGRES_DB=pastehub
